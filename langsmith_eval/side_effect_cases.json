  {
    "id": "se_003_change_train_order",
    "description": "交通改签：原订单变更为 changed，新订单变为 booked，并同步处理前后库存。",
    "side_effect": true,
    "turns": [
      "把我2026-03-21北京到上海的高铁票改签到2026-03-22二等座"
    ],
    "preconditions": {
      "dataset": "baseline",
      "user": "demo_user",
      "requires_existing_order": true,
      "notes": [
        "运行前通过 setup_profile=seed_train_order 注入一笔 2026-03-21 北京到上海 的 booked 高铁订单",
        "2026-03-22 目标车次仍有可用库存"
      ]
    },
    "setup_profile": "seed_train_order",
    "expected": {
      "intents": [
        "change_order"
      ],
      "routed_agents": [
        "TicketOrderAssistant"
      ],
      "response_keywords_all": [
        "2026-03-22"
      ],
      "response_keywords_any": [
        "改签成功",
        "变更成功"
      ],
      "pending_domain": "",
      "pending_empty": true
    },
    "expected_db_changes": {
      "orders": [
        "原订单 status='changed'",
        "新增 1 条 train 订单，status='booked'"
      ],
      "inventory": [
        "原车次库存回补",
        "新车次库存扣减"
      ]
    },
    "db_assertions": {
      "row_count_deltas": [
        {
          "label": "change_train_old_booked_to_zero",
          "table": "orders",
          "filter": {
            "order_type": "train",
            "status": "booked",
            "departure_city": "北京",
            "arrival_city": "上海",
            "departure_time": "2026-03-21 07:00:00",
            "transport_no": "G5",
            "ticket_or_room_type": "二等座",
            "quantity": 1
          },
          "delta": -1
        },
        {
          "label": "change_train_old_changed_plus_one",
          "table": "orders",
          "filter": {
            "order_type": "train",
            "status": "changed",
            "departure_city": "北京",
            "arrival_city": "上海",
            "departure_time": "2026-03-21 07:00:00",
            "transport_no": "G5",
            "ticket_or_room_type": "二等座",
            "quantity": 1
          },
          "delta": 1
        },
        {
          "label": "change_train_new_booked_plus_one",
          "table": "orders",
          "filter": {
            "order_type": "train",
            "status": "booked",
            "departure_city": "北京",
            "arrival_city": "上海",
            "departure_time": "2026-03-22 09:00:00",
            "transport_no": "G13",
            "ticket_or_room_type": "二等座",
            "quantity": 1
          },
          "delta": 1
        }
      ],
      "field_deltas": [
        {
          "label": "change_train_old_inventory_restore",
          "table": "train_tickets",
          "filter": {
            "departure_time": "2026-03-21 07:00:00",
            "train_number": "G5",
            "seat_type": "二等座"
          },
          "field": "remaining_seats",
          "delta": 1
        },
        {
          "label": "change_train_new_inventory_deduct",
          "table": "train_tickets",
          "filter": {
            "departure_time": "2026-03-22 09:00:00",
            "train_number": "G13",
            "seat_type": "二等座"
          },
          "field": "remaining_seats",
          "delta": -1
        }
      ]
    },
    "reset_strategy": "full_rebuild"
  },
  {
    "id": "se_004_create_hotel_order",
    "description": "酒店预订：创建酒店订单，并扣减入住区间各晚库存。",
    "side_effect": true,
    "turns": [
