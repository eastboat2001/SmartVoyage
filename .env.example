SMARTVOYAGE_PROVIDER=openai_compatible
SMARTVOYAGE_MODEL_NAME=qwen-plus-0112

# provider=openai_compatible 时使用
SMARTVOYAGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SMARTVOYAGE_API_KEY=

# provider=ollama 时使用
SMARTVOYAGE_OLLAMA_BASE_URL=http://127.0.0.1:11434

# 可选：为低风险结构化任务启用轻模型
# 推荐先只灰度这些 phase：intent_recognition, weather_plan, ticket_plan, order_date_resolution
# 暂不建议下沉：decision_plan, review_decision, order_operation_extract_cancel_order, order_operation_extract_change_order
SMARTVOYAGE_LIGHT_MODEL_PROVIDER=openai_compatible
SMARTVOYAGE_LIGHT_MODEL_NAME=
SMARTVOYAGE_LIGHT_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SMARTVOYAGE_LIGHT_MODEL_API_KEY=
SMARTVOYAGE_LIGHT_OLLAMA_BASE_URL=http://127.0.0.1:11434
SMARTVOYAGE_LIGHT_MODEL_PHASES=intent_recognition,weather_plan,ticket_plan,order_date_resolution

SMARTVOYAGE_DB_HOST=localhost
SMARTVOYAGE_DB_USER=root
SMARTVOYAGE_DB_PASSWORD=123456
SMARTVOYAGE_DB_NAME=travel_rag


# LangSmith 环境变量
LANGSMITH_API_KEY=


SMARTVOYAGE_TIMEZONE=Asia/Shanghai
SMARTVOYAGE_NOW_OVERRIDE=
SMARTVOYAGE_ORDER_CHECKPOINT_PATH=data/checkpoints/transport_order.pkl
SMARTVOYAGE_CACHE_ENABLED=1
SMARTVOYAGE_REDIS_URL=redis://127.0.0.1:6379/0
SMARTVOYAGE_CACHE_TIME_TTL_SECONDS=10
SMARTVOYAGE_CACHE_WEATHER_TTL_SECONDS=600
SMARTVOYAGE_CACHE_TICKET_TTL_SECONDS=60
