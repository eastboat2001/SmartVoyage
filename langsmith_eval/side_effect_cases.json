[
  {
    "id": "se_001_create_train_order",
    "description": "交通订票：创建一笔新的高铁订单，并扣减余票。",
    "side_effect": true,
    "turns": [
      "帮我预订2026-03-21北京到上海的高铁票，二等座1张"
    ],
    "preconditions": {
      "dataset": "baseline",
      "user": "demo_user",
      "requires_existing_order": false,
      "notes": [
        "2026-03-21 北京到上海高铁存在可订库存",
        "当前用户不存在同日期同车次同席别的重复订单"
      ]
    },
    "setup_profile": "baseline",
    "expected": {
      "intents": [
        "order"
      ],
      "routed_agents": [
        "TicketOrderAssistant"
      ],
      "response_keywords_all": [
        "订单号"
      ],
      "response_keywords_any": [
        "预订成功",
        "订票成功"
      ],
      "pending_domain": "",
      "pending_empty": true
    },
    "expected_db_changes": {
      "orders": [
        "新增 1 条 order_type='train' 订单",
        "新订单 status='booked'"
      ],
      "inventory": [
        "对应 train_tickets.remaining_seats 减 1"
      ]
    },
    "db_assertions": {
      "row_count_deltas": [
        {
          "label": "create_train_booked_order",
          "table": "orders",
          "filter": {
            "order_type": "train",
            "status": "booked",
            "departure_city": "北京",
            "arrival_city": "上海",
            "departure_time": "2026-03-21 07:00:00",
            "transport_no": "G5",
            "ticket_or_room_type": "二等座",
            "quantity": 1
          },
          "delta": 1
        }
      ],
      "field_deltas": [
        {
          "label": "create_train_inventory_delta",
          "table": "train_tickets",
          "filter": {
            "departure_time": "2026-03-21 07:00:00",
            "train_number": "G5",
            "seat_type": "二等座"
          },
          "field": "remaining_seats",
          "delta": -1
        }
      ]
    },
    "reset_strategy": "full_rebuild"
  },
  {
