          "table": "hotel_room_inventory",
          "filter": {
            "hotel_id": 1,
            "stay_date": "2026-03-21",
            "room_type": "高级大床房"
          },
          "field": "remaining_rooms",
          "delta": -1
        },
        {
          "label": "create_hotel_inventory_2026_03_22",
          "table": "hotel_room_inventory",
          "filter": {
            "hotel_id": 1,
            "stay_date": "2026-03-22",
            "room_type": "高级大床房"
          },
          "field": "remaining_rooms",
          "delta": -1
