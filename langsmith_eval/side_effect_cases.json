    "side_effect": true,
    "turns": [
      "从北京出发，结合2026-03-21上海开始两天的天气、交通和酒店，帮我做方案；如果高铁合适就直接帮我订票"
    ],
    "preconditions": {
      "dataset": "baseline",
      "user": "demo_user",
      "requires_existing_order": false,
      "notes": [
        "本次行程没有已预订交通订单",
        "高铁链路存在可订库存"
      ]
