        {
          "label": "cancel_train_cancelled_plus_one",
          "table": "orders",
          "filter": {
            "order_type": "train",
            "status": "cancelled",
            "departure_city": "北京",
            "arrival_city": "上海",
            "departure_time": "2026-03-21 07:00:00",
            "transport_no": "G5",
            "ticket_or_room_type": "二等座",
            "quantity": 1
          },
          "delta": 1
        }
